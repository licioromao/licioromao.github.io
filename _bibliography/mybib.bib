@inproceedings{RFdOOP17,
   abstract = {This paper proposes a sufficient condition for the discrete-time robust H∞ filtering design problem with low-frequency specifications using an extension of the generalized Kalman-Yakubovich-Popov lemma. The matrices of the system are supposed to be uncertain, time-invariant and to belong to a polytopic domain. The proposed approach takes advantage of a non-minimal filter structure, that is, a filter with order greater than the order of the system being filtered, to provide improved H∞ bounds for low-frequency specifications. The condition can be solved by means of linear matrix inequality relaxations with slack variables and Lyapunov matrices which are considered as homogeneous polynomials of arbitrary degree. Numerical examples illustrate the improvements on the H∞ bounds provided by the non-minimal filter structure in combination with the more accurate polynomial approximations (higher degrees) for the optimization variables.},
   author = {Lício B.R.R. Romão and Luciano Frezzatto and Maurício C. de Oliveira and Ricardo C.L.F. Oliveira and Pedro L.D. Peres},
   doi = {10.1016/j.ifacol.2017.08.1044},
   issn = {24058963},
   issue = {1},
   journal = {IFAC-PapersOnLine},
   keywords = {Filtering,Generalized Kalman-Yakubovich-Popov Lemma,Linear time-invariant uncertain systems,Low-frequency Specifications,Robust linear matrix inequalities},
   month = {7},
   pages = {6477-6482},
   publisher = {Elsevier B.V.},
   title = {Non-minimal order low-frequency H-inf filtering for uncertain discrete-time systems},
   volume = {50},
   year = {2017},
}
